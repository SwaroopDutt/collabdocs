{
  "info": {
    "name": "CollabDocs API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "access_token", "value": "" },
    { "key": "workspace_id", "value": "" },
    { "key": "document_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"swaroop@test.com\",\n  \"password\": \"pass1234\",\n  \"first_name\": \"Swaroop\"\n}" },
            "url": "{{base_url}}/auth/register/"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"swaroop@test.com\",\n  \"password\": \"pass1234\"\n}" },
            "url": "{{base_url}}/auth/login/"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/me/"
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Team Alpha\",\n  \"slug\": \"team-alpha\"\n}" },
            "url": "{{base_url}}/workspaces/"
          }
        },
        {
          "name": "List Workspaces",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/workspaces/"
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"teammate@test.com\",\n  \"role\": \"editor\"\n}" },
            "url": "{{base_url}}/workspaces/{{workspace_id}}/members/"
          }
        },
        {
          "name": "Workspace Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/workspaces/{{workspace_id}}/stats/"
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Create Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"workspace\": \"{{workspace_id}}\",\n  \"title\": \"Design Doc\",\n  \"content\": \"Initial content\"\n}" },
            "url": "{{base_url}}/documents/"
          }
        },
        {
          "name": "List Documents (filter+search)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/documents/?workspace={{workspace_id}}&status=draft&search=Design"
          }
        },
        {
          "name": "Edit Document (new version)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Updated content v2\"\n}" },
            "url": "{{base_url}}/documents/{{document_id}}/"
          }
        },
        {
          "name": "Version History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/documents/{{document_id}}/versions/"
          }
        },
        {
          "name": "Revert Version",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"version_number\": 1\n}" },
            "url": "{{base_url}}/documents/{{document_id}}/revert/"
          }
        }
      ]
    },
    {
      "name": "Comments & Tags",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"document\": \"{{document_id}}\",\n  \"content\": \"Looks good\"\n}" },
            "url": "{{base_url}}/comments/"
          }
        },
        {
          "name": "Create Tag",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"workspace\": \"{{workspace_id}}\",\n  \"name\": \"urgent\"\n}" },
            "url": "{{base_url}}/tags/"
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/audit-logs/"
          }
        }
      ]
    }
  ]
}
